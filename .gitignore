# Byte-compiled / cache (root, scripts/, and any other subfolder)
__pycache__/
*.pyc

# LaTeX build artifacts (regenerated by pdflatex every compile; paper.tex and
# paper.pdf are the only LaTeX files that need to be tracked)
paper.aux
paper.log
paper.out
paper.fls
paper.fdb_latexmk
paper.synctex.gz

# Claude Code project config
.claude/

# Raw dataset CSVs — keep the folder structure (.gitkeep), not the files themselves.
# Reviewers download these from the corrected CIC-IDS 2017/2018 re-extraction (see README).
data/raw_data/cicids2017/*
!data/raw_data/cicids2017/.gitkeep
data/raw_data/cicids2018/*
!data/raw_data/cicids2018/.gitkeep

# Step 1's cleaned/combined per-year parquet (+ dtype metadata) — keep the folder, not the files.
data/cc_data/*
!data/cc_data/.gitkeep

# Step 4's train/test split parquet only (large) — everything else in output/4_preprocessing/
# (scaler.json, feature_names.json, label_mapping.json, preprocessing_meta.json,
# train_test_overlap.json) is kept and uploaded.
output/4_preprocessing/cicids2017/train.parquet
output/4_preprocessing/cicids2017/test.parquet
output/4_preprocessing/cicids2018/train.parquet
output/4_preprocessing/cicids2018/test.parquet
